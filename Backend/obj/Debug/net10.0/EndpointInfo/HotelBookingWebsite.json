{
  "openapi": "3.0.4",
  "info": {
    "title": "HotelBookingWebsite",
    "version": "1.0"
  },
  "paths": {
    "/api/Booking": {
      "post": {
        "tags": [
          "Booking"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBookingDto"
